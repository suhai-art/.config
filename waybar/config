{
    "height": 28,
    "spacing": 0,

    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/scratchpad",
        "custom/media"
    ],

    "modules-center": [],

    "modules-right": [
        "pulseaudio",
        "custom/hourly",
        "cpu",
        "memory",
        "temperature",
        "backlight",
        "sway/language",
        "battery",
        "tray",
        "clock"
    ],

    "custom/hourly": {
        "exec": "~/.config/waybar/scripts/hourly-waybar",
        "return-type": "json",
        "interval": 5,
        "tooltip": true
    },

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "warp-on-scroll": false
    },

    "sway/scratchpad": {
        "format": " {count}",
        "show-empty": false,
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },

    "clock": {
        "format": " {:%H:%M}",
        "format-alt": " {:%a %d/%m/%Y}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "format": " {usage}%",
        "tooltip": false,
        "interval": 2
    },

    "memory": {
        "format": " {used:0.1f}G",
        "interval": 5
    },

    "pulseaudio": {
        "format": " {volume}%",
        "format-muted": " muted",
        "on-click": "pavucontrol"
    },

    "battery": {
        "interval": 5,
        "format": " {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%"
    },

    "temperature": {
        "format": " {temperatureC}°C"
    },

    "backlight": {
        "format": " {percent}%"
    },

    "sway/language": {
        "format": " {short}"
    },

    "tray": {
        "spacing": 10
    }
}
